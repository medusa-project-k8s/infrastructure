# Talos sensitive config – source these before running render-talos-config.sh
# Copy to .env.talos and fill in (or use your secret manager to export these).
# Generate new cluster secrets with: talosctl gen config MyCluster https://<controlplane-ip>:6443

# Machine PKI (control plane and workers use same token + CA cert; only control plane has CA key)
export MACHINE_TOKEN=""
export MACHINE_CA_CRT=""
export MACHINE_CA_KEY=""

# Cluster identity
export CLUSTER_ID=""
export CLUSTER_SECRET=""
export CLUSTER_TOKEN=""
export CLUSTER_ENDPOINT="https://192.168.0.150:6443"
export SECRETBOX_ENCRYPTION_SECRET=""

# Kubernetes PKI (control plane only)
export K8S_CA_CRT=""
export K8S_CA_KEY=""
export AGGREGATOR_CA_CRT=""
export AGGREGATOR_CA_KEY=""
export SERVICE_ACCOUNT_KEY=""

# Etcd PKI (control plane only)
export ETCD_CA_CRT=""
export ETCD_CA_KEY=""
